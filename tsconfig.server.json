{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/server",
    "rootDir": ".",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "preserve",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "esModuleInterop": true
  },
  "include": ["src/server", "src/shared"],
  "exclude": ["src/client"]
}
