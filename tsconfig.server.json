{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/server",
    "rootDir": ".",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "preserve",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "esModuleInterop": true
  },
  "include": ["apps/api/src", "apps/api/api", "packages/shared/src"],
  "exclude": ["apps/web"]
}
