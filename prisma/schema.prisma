generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(STUDENT)
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results     TestResult[]
  submissions Submission[]
}

enum Role {
  STUDENT
  CREATOR
  ADMIN
}

model Question {
  id        String   @id @default(uuid())
  content   String
  options   String   // JSON: [{ label: "A", text: "...", scores: { pid: number } }]
  category  String?
  status    Status   @default(PENDING)
  createdBy String?
  createdAt DateTime @default(now())

  templates TemplateQuestion[]
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

model Personality {
  id          String   @id @default(uuid())
  name        String
  title       String
  description String
  traits      String   // JSON: [{ name: "创造力", value: 85 }]
  icon        String
  color       String
  pixelArt    String?  // JSON: ["..####..", ".######.", ...]
  heroImage   String?
  shareImageFallback String?
  status      Status   @default(PENDING)
  createdAt   DateTime @default(now())

  results TestResult[]
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  status      Status   @default(APPROVED)
  createdBy   String?
  scoringRules String? // JSON: { dimensions, resultMap?, tieBreak? }
  createdAt   DateTime @default(now())

  questions TemplateQuestion[]
  results   TestResult[]
}

model TemplateQuestion {
  id         String   @id @default(uuid())
  templateId String
  questionId String
  order      Int

  template   Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([templateId, questionId])
}

model TestResult {
  id            String   @id @default(uuid())
  userId        String?
  guestToken    String?
  templateId    String
  personalityId String
  scores        String   // JSON: { personalityId: score }
  answers       String   // JSON: [{ questionId, optionIndex }]
  createdAt     DateTime @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  personality Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)

  @@index([guestToken])
  @@index([userId])
}

model Submission {
  id         String         @id @default(uuid())
  type       SubmissionType
  content    String         // JSON snapshot
  status     Status         @default(PENDING)
  remark     String?
  creatorId  String
  reviewerId String?
  createdAt  DateTime       @default(now())
  reviewedAt DateTime?

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

enum SubmissionType {
  QUESTION
  PERSONALITY
  TEMPLATE
}
